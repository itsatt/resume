# RAG 系统 API 配置 - 示例文件
# 复制此文件为 .env 并填入你的实际配置

# ===== LLM API 配置（通用） =====
# 说明：选择一个平台，取消对应配置的注释，并填入你的 API Key

# --- 选项 1: 阿里云百炼 (Qwen) ---
# 文档：https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
# LLM_API_KEY=sk-your-alibaba-cloud-api-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- 选项 2: Moonshot (Kimi) ---
# 文档：https://platform.moonshot.cn/docs/api
# LLM_API_KEY=sk-your-moonshot-api-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# --- 选项 3: DeepSeek ---
# 文档：https://platform.deepseek.com/api-docs/
# LLM_API_KEY=sk-your-deepseek-api-key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# --- 选项 4: OpenAI ---
# 文档：https://platform.openai.com/docs/api-reference
# LLM_API_KEY=sk-your-openai-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- 选项 5: 其他兼容 OpenAI 格式的 API ---
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://your-api-endpoint.com/v1
# LLM_MODEL=your-model-name

# 当前使用的配置（取消注释上面一个选项，或在这里直接配置）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ===== RAG 系统配置 =====
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# 向量库配置
VECTOR_STORE_TYPE=faiss
FAISS_PATH=D:/rag_system/vector_store/faiss.index

# 文档目录
DEFAULT_DOCS_PATH=D:/rag_system/docs

# 服务配置
HOST=127.0.0.1
PORT=8000
